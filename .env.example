# Supabase (Frontend)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase (Scanner Agent - service role)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Scanner config (production defaults)
SCANNER_CRON=*/1 * * * *
SCANNER_AGGREGATOR_CRON=*/10 * * * *
SCANNER_SPAM_CRON=*/15 * * * *
SCANNER_AI_JOBS_CRON=*/1 * * * *
SCANNER_REVENUE_COPILOT_CRON=*/1 * * * *
SCANNER_MANAGER_COPILOT_CRON=*/1 * * * *
SCANNER_DAILY_AI_FULL_SCAN_CRON=5 0 * * *
SCANNER_BATCH_SIZE=1000
SCANNER_MAX_RETRIES=3
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# n8n Webhook secret (optional)
WEBHOOK_SECRET=your-webhook-secret-here

# Settings runtime / billing / notifications
APP_BASE_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_your_enterprise_monthly
RESEND_API_KEY=re_your_resend_api_key
UAZAPI_BASE_URL=https://api.uazapi.example
UAZAPI_INSTANCE=default
UAZAPI_TOKEN=your-uazapi-token
WHATSAPP_NOTIFY_PHONE=5511999999999
